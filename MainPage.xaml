<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Parcial_Moviles.ViewModels"
             xmlns:m="clr-namespace:Parcial_Moviles.Models"
             x:Class="Parcial_Moviles.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="11" Spacing="9">


            <Label Text="Fake Store API"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="Black" />


            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="DarkBlue" />

            <Label Text="{Binding StatusMessage}"
                   TextColor="#2E7D32"
                   HorizontalOptions="Center"
                   FontSize="14" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   HorizontalOptions="Center"
                   FontSize="14" />


            <Button Text="Cargar los productos"
                    Command="{Binding LoadProductsCommand}"
                    BackgroundColor="Green"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="50" />


            <CollectionView ItemsSource="{Binding Products}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:Product">
                        <Frame Padding="12"
                               Margin="1"
                               HasShadow="True"
                               BackgroundColor="White"
                               BorderColor="Black"
                               >
                            <VerticalStackLayout Spacing="7">
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       TextColor="Black" />
                                <Label Text="{Binding Category}"
                                       FontSize="14"
                                       TextColor="DarkGray" />
                                <Label Text="{Binding Price, StringFormat='${0:F2}'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#2E7D32" />
                            </VerticalStackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=VerDetalleCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
    
    // Frontend de la aplicacion.